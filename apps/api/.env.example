# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL connection string for application metadata.
# Local: postgresql://postgres:postgres@localhost:5432/averion
# Railway: Use DATABASE_URL from Railway PostgreSQL service (auto-injected)
# Supabase: postgresql://postgres:[password]@[host]:5432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/averion

# Fallback organization UUID used only when a request has no authenticated user.
# Generate a new UUID for each environment or use the default for testing.
DEFAULT_ORGANIZATION_ID=00000000-0000-0000-0000-000000000001

# ============================================================================
# SUPABASE AUTHENTICATION & STORAGE
# ============================================================================

# Supabase project URL used by the backend for auth validation.
# Find in: Supabase Dashboard -> Project Settings -> API -> Project URL
# Required for: Production, Staging, Preview
# Example: https://abcdefghijklmnop.supabase.co
SUPABASE_URL=

# Supabase JWT secret used to validate access tokens from the frontend.
# Find in: Supabase Dashboard -> Project Settings -> API -> JWT Settings
# Required for: Production, Staging, Preview
# NEVER commit the real value - set via Railway/Vercel environment variables
SUPABASE_JWT_SECRET=

# Server-only Supabase service role key for private document storage operations.
# Find in: Supabase Dashboard -> Project Settings -> API -> service_role key
# Required for: Production, Staging, Preview
# NEVER expose to frontend or commit to Git
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================================
# DOCUMENT STORAGE & PROCESSING
# ============================================================================

# Storage backend: "local" for development, "supabase" for deployed environments
# Local: Uses UPLOAD_DIR for file storage
# Supabase: Uses Supabase Storage with SUPABASE_STORAGE_BUCKET
DOCUMENT_STORAGE_BACKEND=local

# Supabase Storage bucket name (required when DOCUMENT_STORAGE_BACKEND=supabase)
SUPABASE_STORAGE_BUCKET=documents

# Maximum document size in bytes (default: 100MB)
MAX_DOCUMENT_SIZE_BYTES=104857600

# Document ingestion job configuration
DOCUMENT_JOB_MAX_ATTEMPTS=3
DOCUMENT_JOB_RETRY_DELAY_SECONDS=30
DOCUMENT_JOB_LEASE_SECONDS=900
DOCUMENT_WORKER_POLL_SECONDS=2

# Maximum chunks per document (prevents memory issues)
DOCUMENT_MAX_CHUNKS=2000

# Batch size for embedding generation
EMBEDDING_BATCH_SIZE=32

# Local-only document storage directory (used when DOCUMENT_STORAGE_BACKEND=local)
UPLOAD_DIR=./uploads

# ============================================================================
# AUTHENTICATION & AUTHORIZATION
# ============================================================================

# Require valid bearer token for API requests
# Local: false (for easier development)
# Preview/Staging/Production: true (enforce authentication)
AUTH_REQUIRED=false

# Optional comma-separated email domains for backend validation
# Leave empty to allow any valid email address
# Example: company.com,partner.com
ALLOWED_EMAIL_DOMAINS=

# ============================================================================
# CORS & SECURITY
# ============================================================================

# Comma-separated frontend origins allowed to call the API
# Local: http://localhost:3000,http://127.0.0.1:3000
# Preview: https://your-preview-*.vercel.app
# Production: https://your-production-domain.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Enable security headers (X-Frame-Options, X-Content-Type-Options, etc.)
SECURITY_HEADERS_ENABLED=true

# Enable request/response logging
REQUEST_LOGGING_ENABLED=true

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# AI/ML CONFIGURATION - EMBEDDINGS
# ============================================================================

# Embedding model for document chunks and queries
# Default: sentence-transformers/all-MiniLM-L6-v2 (384 dimensions)
# Alternative: sentence-transformers/all-mpnet-base-v2 (768 dimensions, higher quality)
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# Preload embedding model at startup (reduces first-request latency)
# Local: false (faster startup)
# Production: true (better performance)
EMBEDDING_MODEL_PRELOAD=false

# ============================================================================
# AI/ML CONFIGURATION - RETRIEVAL
# ============================================================================

# Number of document chunks to retrieve for each chat question
RETRIEVAL_TOP_K=5

# Cosine distance threshold for retrieval (0.0-2.0, lower = more similar)
# Only chunks with score <= threshold are used
# Default 0.8 is validated by tests in test_retrieval_threshold_eval.py
RETRIEVAL_MIN_SCORE=0.8

# ============================================================================
# AI/ML CONFIGURATION - LLM
# ============================================================================

# LLM provider: "mock" (testing), "openai", "groq"
# Local: mock (no API key needed)
# Production: openai or groq (requires API key)
LLM_PROVIDER=mock

# API key for the selected LLM provider
# NEVER commit the real value - set via Railway/Vercel environment variables
# OpenAI: Get from https://platform.openai.com/api-keys
# Groq: Get from https://console.groq.com/keys
LLM_PROVIDER_API_KEY=

# Optional custom base URL for LLM provider (for proxies or alternative endpoints)
LLM_PROVIDER_BASE_URL=

# LLM request timeout in seconds
LLM_PROVIDER_TIMEOUT_SECONDS=30

# Maximum retry attempts for failed LLM requests
LLM_PROVIDER_MAX_RETRIES=2

# LLM model name
# OpenAI: gpt-4o-mini, gpt-4o, gpt-4-turbo
# Groq: llama-3.1-70b-versatile, mixtral-8x7b-32768
LLM_MODEL_NAME=gpt-4o-mini

# LLM temperature (0.0-1.0, lower = more focused/deterministic)
LLM_TEMPERATURE=0.2

# Maximum tokens in LLM response
LLM_MAX_TOKENS=1000

# ============================================================================
# AI/ML CONFIGURATION - TRANSCRIPTION
# ============================================================================

# Transcription provider: "disabled", "openai", "groq"
# Local: disabled (unless testing speech-to-text)
# Production: openai or groq (requires API key)
TRANSCRIPTION_PROVIDER=disabled

# API key for transcription provider (same as LLM or separate)
# NEVER commit the real value - set via Railway/Vercel environment variables
TRANSCRIPTION_PROVIDER_API_KEY=

# Optional custom base URL for transcription provider
TRANSCRIPTION_PROVIDER_BASE_URL=

# Transcription model name
# OpenAI: whisper-1
# Groq: whisper-large-v3, whisper-large-v3-turbo
TRANSCRIPTION_MODEL_NAME=whisper-large-v3

# Transcription request timeout in seconds
TRANSCRIPTION_TIMEOUT_SECONDS=60

# Maximum retry attempts for failed transcription requests
TRANSCRIPTION_MAX_RETRIES=2

# ============================================================================
# ENVIRONMENT-SPECIFIC NOTES
# ============================================================================

# LOCAL DEVELOPMENT:
# - Use DATABASE_URL with local PostgreSQL
# - Set DOCUMENT_STORAGE_BACKEND=local
# - Set AUTH_REQUIRED=false
# - Set LLM_PROVIDER=mock or use real provider with API key
# - Set CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# RAILWAY (API):
# - DATABASE_URL is auto-injected from PostgreSQL service
# - Set DOCUMENT_STORAGE_BACKEND=supabase
# - Set AUTH_REQUIRED=true
# - Set all SUPABASE_* variables
# - Set LLM_PROVIDER_API_KEY and TRANSCRIPTION_PROVIDER_API_KEY
# - Set CORS_ORIGINS to match Vercel preview/production domains

# VERCEL (Frontend):
# - See apps/web/.env.example for frontend-specific variables
# - Frontend uses NEXT_PUBLIC_* variables (safe to expose)
# - Backend uses server-only secrets (never expose)
