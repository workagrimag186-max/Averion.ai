# PostgreSQL connection string for application metadata.
# Use a local database in development and a managed database in production.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/averion

# Temporary organization used until real auth and organization management exist.
DEFAULT_ORGANIZATION_ID=00000000-0000-0000-0000-000000000001

# Supabase project URL used by future auth-aware API code.
# Find it in Supabase Dashboard -> Project Settings -> API -> Project URL.
SUPABASE_URL=

# Supabase JWT secret used by the backend to validate access tokens.
# Find it in Supabase Dashboard -> Project Settings -> API -> JWT Settings.
# Keep the real value in apps/api/.env, never in Git.
SUPABASE_JWT_SECRET=

# Optional comma-separated email domains enforced by the backend.
# Leave empty to allow any valid email address.
# Example: gmail.com,googlemail.com
ALLOWED_EMAIL_DOMAINS=

# Require a valid bearer token for API requests.
# Keep false for local development until frontend auth env values are configured.
AUTH_REQUIRED=false

# Local folder where uploaded source documents can be stored during development.
UPLOAD_DIR=./uploads

# Comma-separated frontend origins allowed to call the API in a browser.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Embedding model used to convert document chunks and questions into vectors.
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# Number of chunks to retrieve for each chat question.
RETRIEVAL_TOP_K=5

# LLM provider name. Options: "mock" (for testing), "openai" (requires API key)
LLM_PROVIDER=mock

# API key for the selected LLM provider.
# Keep the real value in apps/api/.env, never in Git.
LLM_PROVIDER_API_KEY=

# LLM model name (used when provider is "openai")
LLM_MODEL_NAME=gpt-4o-mini

# LLM temperature (0.0-1.0, lower = more focused/deterministic)
LLM_TEMPERATURE=0.2

# Maximum tokens in LLM response
LLM_MAX_TOKENS=1000
