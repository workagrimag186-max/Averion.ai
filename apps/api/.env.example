# PostgreSQL connection string for application metadata.
# Use a local database in development and a managed database in production.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/averion

# Temporary organization used until real auth and organization management exist.
DEFAULT_ORGANIZATION_ID=00000000-0000-0000-0000-000000000001

# Supabase project URL used by future auth-aware API code.
# Find it in Supabase Dashboard -> Project Settings -> API -> Project URL.
SUPABASE_URL=

# Supabase JWT secret used by the backend to validate access tokens.
# Find it in Supabase Dashboard -> Project Settings -> API -> JWT Settings.
# Keep the real value in apps/api/.env, never in Git.
SUPABASE_JWT_SECRET=

# Server-only Supabase service role key used for private document storage.
# Find it in Supabase Dashboard -> Project Settings -> API.
# Never expose this value to the frontend.
SUPABASE_SERVICE_ROLE_KEY=

# Use "local" for local development and "supabase" for deployed environments.
DOCUMENT_STORAGE_BACKEND=local
SUPABASE_STORAGE_BUCKET=documents
MAX_DOCUMENT_SIZE_BYTES=104857600
DOCUMENT_JOB_MAX_ATTEMPTS=3
DOCUMENT_JOB_RETRY_DELAY_SECONDS=30
DOCUMENT_JOB_LEASE_SECONDS=900
DOCUMENT_WORKER_POLL_SECONDS=2
DOCUMENT_MAX_CHUNKS=2000
EMBEDDING_BATCH_SIZE=32

# Optional comma-separated email domains enforced by the backend.
# Leave empty to allow any valid email address.
# Example: gmail.com,googlemail.com
ALLOWED_EMAIL_DOMAINS=

# Require a valid bearer token for API requests.
# Keep false for local development until frontend auth env values are configured.
AUTH_REQUIRED=false

# Local-only document object store used when DOCUMENT_STORAGE_BACKEND=local.
UPLOAD_DIR=./uploads

# Comma-separated frontend origins allowed to call the API in a browser.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SECURITY_HEADERS_ENABLED=true
REQUEST_LOGGING_ENABLED=true

# Embedding model used to convert document chunks and questions into vectors.
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_MODEL_PRELOAD=false

# Number of chunks to retrieve for each chat question.
RETRIEVAL_TOP_K=5

# Cosine distance threshold for retrieval (0.0-2.0, lower = more similar).
# Only chunks with score <= threshold are used. Default 0.8 is backed by tests.
RETRIEVAL_MIN_SCORE=0.8

# LLM provider name. Options: "mock" (for testing), "openai" (requires API key), "groq"
LLM_PROVIDER=mock

# API key for the selected LLM provider.
# Keep the real value in apps/api/.env, never in Git.
LLM_PROVIDER_API_KEY=
LLM_PROVIDER_BASE_URL=
LLM_PROVIDER_TIMEOUT_SECONDS=30
LLM_PROVIDER_MAX_RETRIES=2

# LLM model name (used when provider is "openai" or "groq")
LLM_MODEL_NAME=gpt-4o-mini

# LLM temperature (0.0-1.0, lower = more focused/deterministic)
LLM_TEMPERATURE=0.2

# Maximum tokens in LLM response
LLM_MAX_TOKENS=1000

# Transcription provider is independently configured from chat.
# Use "disabled", "openai", or "groq".
TRANSCRIPTION_PROVIDER=disabled
TRANSCRIPTION_PROVIDER_API_KEY=
TRANSCRIPTION_PROVIDER_BASE_URL=
TRANSCRIPTION_MODEL_NAME=whisper-large-v3
TRANSCRIPTION_TIMEOUT_SECONDS=60
TRANSCRIPTION_MAX_RETRIES=2
