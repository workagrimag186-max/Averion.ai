# ============================================================================
# FRONTEND CONFIGURATION - PUBLIC VARIABLES
# ============================================================================
# All NEXT_PUBLIC_* variables are exposed to the browser.
# NEVER put secrets or sensitive keys in NEXT_PUBLIC_* variables.
# ============================================================================

# ============================================================================
# API BACKEND URL
# ============================================================================

# Public base URL for the FastAPI backend API
# Local: http://127.0.0.1:8000 or http://localhost:8000
# Preview: https://your-railway-preview.up.railway.app
# Production: https://your-railway-production.up.railway.app
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# ============================================================================
# SUPABASE AUTHENTICATION (PUBLIC)
# ============================================================================

# Public Supabase project URL used by the browser auth client
# Find in: Supabase Dashboard -> Project Settings -> API -> Project URL
# Example: https://abcdefghijklmnop.supabase.co
# Required for: All environments
NEXT_PUBLIC_SUPABASE_URL=

# Public Supabase anon key used by the browser auth client
# Find in: Supabase Dashboard -> Project Settings -> API -> anon public key
# This key is safe to expose - it only allows public operations
# Required for: All environments
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ============================================================================
# AUTHENTICATION REDIRECT
# ============================================================================

# URL Supabase should return to after email verification or OAuth callbacks
# Must match the redirect URL configured in Supabase Dashboard
# Local: http://localhost:3000/auth/callback
# Preview: https://your-preview-*.vercel.app/auth/callback
# Production: https://your-production-domain.com/auth/callback
NEXT_PUBLIC_AUTH_REDIRECT_URL=http://localhost:3000/auth/callback

# ============================================================================
# EMAIL DOMAIN VALIDATION (OPTIONAL)
# ============================================================================

# Optional comma-separated email domains for frontend validation
# Leave empty to allow any valid email address
# Example: company.com,partner.com
# Note: Backend also validates this independently via ALLOWED_EMAIL_DOMAINS
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAINS=

# ============================================================================
# ENVIRONMENT-SPECIFIC CONFIGURATION GUIDE
# ============================================================================

# LOCAL DEVELOPMENT:
# - NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
# - NEXT_PUBLIC_AUTH_REDIRECT_URL=http://localhost:3000/auth/callback
# - Set NEXT_PUBLIC_SUPABASE_URL and NEXT_PUBLIC_SUPABASE_ANON_KEY from Supabase Dashboard

# VERCEL PREVIEW (Automatic for PRs):
# - NEXT_PUBLIC_API_BASE_URL=https://your-railway-preview.up.railway.app
# - NEXT_PUBLIC_AUTH_REDIRECT_URL=https://your-preview-*.vercel.app/auth/callback
# - Use same Supabase project as production or separate preview project
# - Configure in Vercel Dashboard -> Project Settings -> Environment Variables -> Preview

# VERCEL PRODUCTION:
# - NEXT_PUBLIC_API_BASE_URL=https://your-railway-production.up.railway.app
# - NEXT_PUBLIC_AUTH_REDIRECT_URL=https://your-production-domain.com/auth/callback
# - Configure in Vercel Dashboard -> Project Settings -> Environment Variables -> Production
# - Ensure Railway API CORS_ORIGINS includes your Vercel production domain

# ============================================================================
# IMPORTANT SECURITY NOTES
# ============================================================================

# 1. NEVER put sensitive secrets in NEXT_PUBLIC_* variables
#    - These are exposed to the browser and visible in client-side code
#    - Only use NEXT_PUBLIC_* for non-sensitive configuration

# 2. Backend secrets (API keys, service role keys) go in Railway environment:
#    - SUPABASE_JWT_SECRET (backend only)
#    - SUPABASE_SERVICE_ROLE_KEY (backend only)
#    - LLM_PROVIDER_API_KEY (backend only)
#    - DATABASE_URL (backend only)

# 3. OAuth Configuration:
#    - Configure OAuth providers in Supabase Dashboard -> Authentication -> Providers
#    - Add redirect URLs for each environment (local, preview, production)
#    - Example: http://localhost:3000/auth/callback, https://your-domain.com/auth/callback

# 4. CORS Configuration:
#    - Railway API must allow your Vercel domains in CORS_ORIGINS
#    - Include both preview and production domains
#    - Example: https://your-preview-*.vercel.app,https://your-production-domain.com
